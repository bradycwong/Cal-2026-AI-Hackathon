# Lab — server-side keys ONLY. Never shipped to the browser.
# Copy to .env and fill in. The typed demo works with NO keys (deterministic router).

ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=

# Router model + behaviour.
LAB_MODEL=claude-haiku-4-5
# auto = LLM when ANTHROPIC_API_KEY is set, else deterministic fallback.
# Options: auto | llm | deterministic
ROUTER_MODE=auto

# Protocol import parser (POST /api/protocols/import).
# auto = LLM-assisted when ANTHROPIC_API_KEY is set, deterministic fallback otherwise.
# Options: auto | llm | deterministic
IMPORT_MODE=auto

# Voice (Deepgram). Wake word gates which spoken utterances become commands.
DEEPGRAM_MODEL=nova-3
DEEPGRAM_TTS_MODEL=aura-asteria-en   # AI voice output (reuses DEEPGRAM_API_KEY)
LAB_WAKE_REQUIRED=true     # set false to route every utterance (no "Hey Lab")
LAB_WAKE_WORD=lab
LAB_WAKE_WINDOW_S=8        # follow-up window after the wake word (seconds)

# Log persistence. Default: backend/data/lab.db. Use ":memory:" to disable.
LAB_DB_PATH=

# Demo reset safety. false = keep persisted notes; true = wipe notes on Reset Demo.
LAB_DEMO_MODE=false

# Observability — Arize AX tracing. OFF unless BOTH are set (and always off under
# pytest). ARIZE_SPACE_ID is an identifier (not a secret); ARIZE_API_KEY is a
# secret — get it at https://app.arize.com/admin > API Keys. Traces land in the
# Arize project "cal-2026-lab".
ARIZE_SPACE_ID=
ARIZE_API_KEY=

