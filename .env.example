# Otto — server-side keys ONLY. Never shipped to the browser.
# Copy to .env and fill in. The typed demo works with NO keys (deterministic router).

ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=

# Router model + behaviour.
OTTO_MODEL=claude-haiku-4-5
# auto = LLM when ANTHROPIC_API_KEY is set, else deterministic fallback.
# Options: auto | llm | deterministic
ROUTER_MODE=auto
