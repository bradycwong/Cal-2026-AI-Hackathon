# Otto — server-side keys ONLY. Never shipped to the browser.
# Copy to .env and fill in. The typed demo works with NO keys (deterministic router).

ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=

# Router model + behaviour.
OTTO_MODEL=claude-haiku-4-5
# auto = LLM when ANTHROPIC_API_KEY is set, else deterministic fallback.
# Options: auto | llm | deterministic
ROUTER_MODE=auto

# Voice (Deepgram). Wake word gates which spoken utterances become commands.
DEEPGRAM_MODEL=nova-2
OTTO_WAKE_REQUIRED=true     # set false to route every utterance (no "Hey Otto")
OTTO_WAKE_WORD=otto
OTTO_WAKE_WINDOW_S=8        # follow-up window after the wake word (seconds)

# Log persistence. Default: backend/data/otto.db. Use ":memory:" to disable.
OTTO_DB_PATH=

# Auto-timers: a step with a duration_s auto-starts its countdown when it
# becomes the current step. Set false to require a spoken/typed "start timer".
OTTO_AUTO_TIMERS=true
